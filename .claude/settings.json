{
  "companyAnnouncements": [
    "Welcome to FlexMeasures! Review our developer guidelines at flexmeasures.readthedocs.io/stable/dev/setup-and-guidelines.html",
    "Reminder: use `uv tool install pre-commit and `pre-commit install` to auto-apply formatting and code style suggestions."
  ],
  "permissions": {
    "deny": [
      "Read(./instance/**)",
      "Read(./flexmeasures-instance/**)",
      "Read(**.sql)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Bash(cat *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)",
      "Bash(less *.env*)",
      "Bash(more *.env*)",
      "Bash(nl *.env*)",
      "Bash(xxd *.env*)",
      "Bash(od *.env*)",
      "Bash(strings *.env*)",
      "Bash(sort *.env*)",
      "Bash(awk * *.env*)",
      "Bash(sed * *.env*)",
      "Bash(grep * *.env*)",
      "Bash(rg * *.env*)"
    ],
    "allow": [
      "Bash(uv sync *)",
      "Bash(uv pip *)",
      "Bash(uv run *)",
      "Bash(uv cache *)",
      "Bash(uv tool *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git log *)",
      "Bash(git worktree *)",
      "Bash(pre-commit install *)",
      "Bash(pre-commit run *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-env-read.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-check.sh\"",
            "if": "Bash(git commit:*)",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/test-reminder.sh\"",
            "if": "Bash(git push:*)",
            "timeout": 10
          }
        ]
      }
    ]
  }
}